# API URL для розробки.
# Docker API (рекомендовано): http://localhost:8080
# Локальний .NET dev:         http://localhost:5224
# Docker nginx (порожньо):    (залишити порожнім — nginx сам проксирує)
VITE_API_URL=http://localhost:8080

# --- Firebase Cloud Messaging (FCM) ---
# From Firebase Console → Project Settings → General → Your apps → Web app → Config
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# From Firebase Console → Project Settings → Cloud Messaging → Web Push certificates → Key pair
VITE_FIREBASE_VAPID_KEY=
