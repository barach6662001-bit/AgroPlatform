# API URL для розробки.
# Docker API (рекомендовано): http://localhost:8080
# Локальний .NET dev:         http://localhost:5224
# Docker nginx (порожньо):    (залишити порожнім — nginx сам проксирує)
VITE_API_URL=http://localhost:8080

# VAPID public key for Web Push notifications (optional).
# Generate a key pair: npx web-push generate-vapid-keys
# Leave empty to skip push subscription (permission is still requested).
VITE_VAPID_PUBLIC_KEY=
