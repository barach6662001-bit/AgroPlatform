# API URL для розробки.
# Docker API (рекомендовано): http://localhost:8080
# Локальний .NET dev:         http://localhost:5224
# Docker nginx (порожньо):    (залишити порожнім — nginx сам проксирує)
VITE_API_URL=http://localhost:8080

# VAPID public key for Web Push notifications (optional).
# Generate a key pair: npx web-push generate-vapid-keys
# Leave empty to skip push subscription (permission is still requested).
VITE_VAPID_PUBLIC_KEY=

# Dev-only auth bypass (Replit sandbox / offline preview only).
# When `true` AND the build is in dev mode (`import.meta.env.DEV`), the app
# auto-logs-in with a mock user, pre-seeds the Dashboard React Query cache with
# fake data, and short-circuits all `/api/*` requests. A red "DEV MOCK MODE"
# banner is shown at the top. NEVER set this to `true` for a production build —
# it is impossible to enable in prod regardless, but keep it `false` by default.
VITE_BYPASS_AUTH=false

# Public demo mode — when true, the site auto-logs in every visitor as the
# demo user (credentials below) and hides the login screen. Unlike
# VITE_BYPASS_AUTH this works in production builds too. Use for public
# preview sites. Set back to false and rebuild to restore normal login.
VITE_PUBLIC_DEMO_MODE=false
VITE_PUBLIC_DEMO_EMAIL=demo@agro.local
VITE_PUBLIC_DEMO_PASSWORD=DemoPass1
