{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Warning",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact"
        }
      }
    ]
  },
  "Swagger": {
    "Enabled": false
  },
  "Cors": {
    "AllowedOrigins": []
  },
  "RateLimiting": {
    "ReadPermitLimit": 200,
    "WritePermitLimit": 50,
    "WindowSeconds": 60,
    "SegmentsPerWindow": 4
  }
}
